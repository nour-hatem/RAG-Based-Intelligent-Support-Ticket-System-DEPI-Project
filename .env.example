# ── Required ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Shared secret used by docker-compose to authenticate the frontend → backend
# proxy route. Must match backend-api/.env's API_KEY value exactly.
# Also passed to the frontend container as BACKEND_API_KEY at runtime.
API_KEY=changeme-generate-a-real-key

# ── Optional — defaults match settings.py ────────────────────────────────────
MODEL_NAME=llama-3.1-8b-instruct
EMBED_MODEL=all-MiniLM-L6-v2
TOP_K=5
EVAL_SAMPLE_SIZE=250
FAISS_INDEX_PATH=faiss/faiss.index
TRAIN_CSV_PATH=data/processed/train.csv
TEST_CSV_PATH=data/processed/test.csv