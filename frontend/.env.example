# ── Frontend environment variables ───────────────────────────────────────────
#
# Copy this file to .env.local and fill in the values for local development.
# In Docker, these are injected via docker-compose.yml — do NOT bake secrets
# into the image.
#
# NEXT_PUBLIC_* vars are baked into the client JS bundle at build time.
# All other vars are server-side only (read by Next.js Route Handlers).

# ── Optional (client-side) ───────────────────────────────────────────────────
# Base URL the browser uses when calling lib/api.ts directly.
# Leave empty (default) to use same-origin, which works for local `npm run dev`
# because the Next.js dev server proxies /api/* to the backend route handler.
# In Docker, docker-compose bakes in http://localhost:8000 at build time.
NEXT_PUBLIC_API_URL=

# ── Optional (server-side, route handler only) ───────────────────────────────
# URL the Next.js server uses to reach the backend from inside the container.
# In Docker this is http://api:8000 (Docker DNS). For local dev, leave at default.
BACKEND_API_URL=http://127.0.0.1:8000

# ── Required for real backend calls (server-side, route handler only) ─────────
# Must match the API_KEY / API_KEY value in backend-api/.env exactly.
# Without this the /api/tickets/respond proxy returns 401 from the backend.
BACKEND_API_KEY=changeme-generate-a-real-key
